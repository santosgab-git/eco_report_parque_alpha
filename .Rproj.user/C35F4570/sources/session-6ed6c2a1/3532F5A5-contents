#| label: Función formatear lista en español

# ===========================================
# FUNCIÓN: FORMATEAR LISTAS CON "Y / E"
# ===========================================

formatear_lista <- function(x) {
  
  x <- trimws(na.omit(x))
  
  if (length(x) == 0) return("")
  if (length(x) == 1) return(x)
  
  # función para limpiar latex
  limpiar <- function(txt) {
    txt %>%
      gsub("\\\\textit\\{|\\}", "", .) %>%  # quita \textit{}
      trimws()
  }
  
  # =========================
  # CASO 2 ELEMENTOS
  # =========================
  if (length(x) == 2) {
    
    segundo_limpio <- limpiar(x[2])
    
    conj <- if (grepl("^(i|hi)", segundo_limpio, ignore.case = TRUE)) " e " else " y "
    
    return(paste0(x[1], conj, x[2]))
  }
  
  # =========================
  # MÁS DE 2 ELEMENTOS
  # =========================
  ultima <- x[length(x)]
  ultima_limpia <- limpiar(ultima)
  
  resto <- paste(x[-length(x)], collapse = ", ")
  
  conj <- if (grepl("^(i|hi)", ultima_limpia, ignore.case = TRUE)) " e " else " y "
  
  return(paste0(resto, conj, ultima))
}
