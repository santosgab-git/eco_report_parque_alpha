generar_texto_grupo <- function(df, grupo, mes, año, manejo) {

  df_filtrado <- df %>%
    filter(Clase %in% grupos[[grupo]], Manejo == manejo)
  
  # =========================
  # REUBICACIÓN (solo rescate)
  # =========================
  texto_reubicacion <- ""
  
  if (manejo == "Rescate") {
    
    df_rescate <- df_filtrado %>%
      filter(!is.na(Reubicado))
    
    total_rescatados <- sum(df_rescate$Abundancia, na.rm = TRUE)
    
    total_reubicados <- df_rescate %>%
      filter(tolower(Reubicado) == "si") %>%
      summarise(total = sum(Abundancia, na.rm = TRUE)) %>%
      pull(total)
    
    if (total_rescatados > 0) {
      
      if (total_reubicados == total_rescatados) {
        
        texto_reubicacion <- ifelse(
          total_rescatados == 1,
          "El individuo rescatado fue reubicado exitosamente en las áreas dispuestas para este fin.",
          "Todos los individuos rescatados fueron reubicados exitosamente en las áreas dispuestas para este fin."
      )
        
      } else {
        
        texto_reubicacion <- paste0(
          "De ",
          ifelse(total_rescatados == 1, "1 individuo rescatado", paste0("los ", total_rescatados, " individuos rescatados")),
          ", ",
          total_reubicados, " ",
          ifelse(total_reubicados == 1, "fue reubicado", "fueron reubicados"),
          " exitosamente en las áreas dispuestas para este fin."
        )
      }
    }
  }

  if (nrow(df_filtrado) == 0) {
    return(paste0(
      "No se registraron individuos de ", grupo,
      " mediante ", tolower(manejo),
      " durante el mes de ", mes, " de ", año, "."
    ))
  }

  clases <- unique(df_filtrado$Clase)
  solo_una_clase <- length(clases) == 1
  
  textos_clase <- c()

  for (i in seq_along(clases)) {

    clase <- clases[i]
    df_clase <- df_filtrado %>% filter(Clase == clase)

    total <- sum(df_clase$Abundancia)

    n_sp <- n_distinct(df_clase$Especie)
    n_fam <- n_distinct(df_clase$Familia)
    n_ord <- n_distinct(df_clase$Orden)

    especie_top <- top_n_con_empates(df_clase, "Especie", 3, TRUE)
    area_top <- top_n_con_empates(df_clase, "Area", 3, FALSE)
    
    # referencias dinámicas
    ref_tabla <- paste0("**", "@tbl-", grupo, "-", tolower(manejo), "**")
    ref_fig   <- paste0("**", "@fig-", grupo, "-", tolower(manejo), "**")

    # especie singular/plural
    if (especie_top$n == 1) {
      txt_especie <- paste0("La especie más abundante fue ", especie_top$texto)
    } else {
      txt_especie <- paste0("Las especies más abundantes fueron ", especie_top$texto)
    }

    # =========================
    # CASO HERPETOS CON UNA SOLA CLASE
    # =========================
    if (grupo == "herpetofauna" && solo_una_clase) {
      texto_clase <- paste0(
        "se registraron ", total,
        " individuos, correspondientes en su totalidad a la clase ", clase, ", donde se registraron ",
        n_sp, " ", pluralizar(n_sp, "especie", "especies"), ", ",
        n_fam, " ", pluralizar(n_fam, "familia", "familias"), " y ",
        n_ord, " ", pluralizar(n_ord, "orden", "órdenes"), " (", ref_tabla, "). ", 
        txt_especie,
        " (", ref_fig, "**A**). ",
        "La mayor abundancia se registró en ", area_top$texto, " (", ref_fig, "**B**)." 
      )

    } else {

      # CONTROL CORRECTO DE MAYÚSCULAS
      if (solo_una_clase) {
        inicio_clase <- ""
      } else if (i == 1) {
        inicio_clase <- paste0("en la clase ", clase, " ")
      } else {
        inicio_clase <- paste0("En la clase ", clase, " ")
      }

      texto_clase <- paste0(
        inicio_clase,
        "se registr",
        ifelse(total == 1, "ó ", "aron "),
        total, " ",
        pluralizar(total, "individuo", "individuos"),
        " en ",
        n_sp, " ", pluralizar(n_sp, "especie", "especies"), ", ",
        n_fam, " ", pluralizar(n_fam, "familia", "familias"), " y ",
        n_ord, " ", pluralizar(n_ord, "orden", "órdenes"),
        " (", ref_tabla, "). ", 
        txt_especie,
        " (", ref_fig, "**A**). ",
        "La mayor abundancia se registró en ", area_top$texto,
        " (", ref_fig, "**B**)."
      )
    }

    textos_clase <- c(textos_clase, texto_clase)
  }

  # ============================
  # HERPETOS: CLASES FALTANTES
  # ============================
  textos_faltantes <- c()

  if (grupo == "herpetofauna") {

    clases_esperadas <- c("Amphibia", "Reptilia")
    faltantes <- setdiff(clases_esperadas, clases)

    for (cl in faltantes) {
      textos_faltantes <- c(
        textos_faltantes,
        paste0("No se registraron individuos de la clase ", cl, ".")
      )
    }
  }

  # =========================
  # TEXTO FINAL
  # =========================
  texto_final <- paste0(
    "Durante el mes de ", mes, " de ", año,
    ", en las actividades de ", tolower(manejo),
    " de ", grupo, ", ",
    paste(textos_clase, collapse = "\n\n"),
    ifelse(length(textos_faltantes) > 0,
           paste0(" ", paste(textos_faltantes, collapse = " ")),
           ""),
    ifelse(texto_reubicacion != "",
         paste0(" ", texto_reubicacion),
         "")
  )

  return(texto_final)
}

# ===========================================
# FUNCIÓN: TEXTO DE CONSERVACIÓN 
# ===========================================

generar_texto_conservacion <- function(df, grupo, mes, año) {
  
  if (nrow(df) == 0) return(NULL)

  # LIMPIEZA Y CLASIFICACIÓN
  df_sp <- df %>%
    distinct(Especie, IUCN, CITES, Distribucion) %>%
    mutate(
      IUCN_clean = case_when(
        grepl("LC", IUCN) ~ "LC",
        grepl("NT", IUCN) ~ "NT",
        grepl("VU", IUCN) ~ "VU",
        grepl("EN", IUCN) ~ "EN",
        grepl("CR", IUCN) ~ "CR",
        grepl("NE", IUCN) ~ "NE",
        grepl("DD", IUCN) ~ "DD",
        TRUE ~ "OTRO"
      ),
      # Traducción de siglas para fluidez
      IUCN_label = case_when(
        IUCN_clean == "VU" ~ "Vulnerable",
        IUCN_clean == "EN" ~ "En Peligro",
        IUCN_clean == "CR" ~ "En Peligro Crítico",
        TRUE ~ ""
      ),
      CITES_clean = gsub("Apéndice ", "", CITES),
      # Clasificación exacta de endemismo
      Tipo_Endemismo = case_when(
        grepl("Casi Endémica", Distribucion, ignore.case = TRUE) ~ "casi endémica",
        grepl("Endémica", Distribucion, ignore.case = TRUE) ~ "endémica",
        TRUE ~ "No"
      )
    )

  # ===========================================
  # LÓGICA UICN
  # ===========================================
  total_sp <- nrow(df_sp)
  n_lc <- sum(df_sp$IUCN_clean == "LC")
  prop_lc <- n_lc / total_sp
  
  # Base del texto (IUCN al principio para que fluya mejor)
  if (prop_lc == 1) {
    texto_iucn <- paste0("Según la UICN, para el mes de ", mes, " de ", año, ", todas las especies registradas se encuentran en Preocupación Menor (LC).")
  } else if (prop_lc > 0.5) {
    texto_iucn <- paste0("Según la UICN, para el mes de ", mes, " de ", año, ", la mayoría de las especies se encuentran en Preocupación Menor (LC).")
  } else {
    texto_iucn <- paste0("Para el mes de ", mes, " de ", año, ", se registraron diversas categorías de conservación según la UICN.")
  }

  # Especies en riesgo (VU, EN, CR)
  riesgo <- df_sp %>% filter(IUCN_clean %in% c("VU", "EN", "CR"))
  
  if (nrow(riesgo) > 0) {
    # Creamos el texto
    lista_riesgo <- paste0("\\textit{", riesgo$Especie, "} (", riesgo$IUCN_label, " - ", riesgo$IUCN_clean, ")")
    u_sp_r <- tail(riesgo$Especie, 1)
    con_r <- if(grepl("^[Ii]|^[Hh][Ii]", u_sp_r)) " e " else " y "
    
    # Construcción de la frase 
    v_identificar <- if(nrow(riesgo) == 1) "se identificó la especie " else "se identificaron las especies "
    
    texto_iucn <- paste0(texto_iucn, " No obstante, ", v_identificar, 
                         knitr::combine_words(lista_riesgo, and = con_r, sep = ", "), ".")
  }

  # ===========================================
  # LÓGICA CITES
  # ===========================================
  cites_df <- df_sp %>% filter(!is.na(CITES) & CITES != "NA" & CITES != "" & CITES != "NONE")
  
  if (nrow(cites_df) > 0) {
    # Solo el número en el paréntesis para no repetir "Apéndice"
    lista_cites <- paste0("\\textit{", cites_df$Especie, "} (", cites_df$CITES_clean, ")")
    u_sp_c <- tail(cites_df$Especie, 1)
    con_c <- if(grepl("^[Ii]|^[Hh][Ii]", u_sp_c)) " e " else " y "
    
    texto_cites <- paste0("En cuanto al convenio CITES, se ", 
                          if(nrow(cites_df) == 1) "incluye en sus apéndices a " else "incluyen en sus apéndices a ", 
                          knitr::combine_words(lista_cites, and = con_c, sep = ", "), ".")
  } else {
    texto_cites <- "No se reportaron especies bajo la convención CITES."
  }

  # ===========================================
  # LÓGICA DE ENDEMISMO
  # ===========================================
  endemicas <- df_sp %>% filter(Tipo_Endemismo != "No")
  
  if (nrow(endemicas) > 0) {
    # Aquí especificamos si es endémica o casi endémica individualmente
    lista_endo <- paste0("\\textit{", endemicas$Especie, "} (", endemicas$Tipo_Endemismo, ")")
    u_sp_e <- tail(endemicas$Especie, 1)
    con_e <- if(grepl("^[Ii]|^[Hh][Ii]", u_sp_e)) " e " else " y "
    
    texto_endemismo <- paste0("Respecto al grado de endemismo, se documentó la presencia de ", 
                              knitr::combine_words(lista_endo, and = con_e, sep = ", "), ".")
  } else {
    texto_endemismo <- "No se registraron especies con grado de endemismo para el país."
  }

  # UNIÓN FINAL
  return(paste(texto_iucn, texto_cites, texto_endemismo, sep = " "))
}
