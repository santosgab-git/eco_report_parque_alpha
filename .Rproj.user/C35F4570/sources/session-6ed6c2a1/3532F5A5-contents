  ahuy <- df_proc %>%
    dplyr::filter(Manejo == "Ahuyentamiento") %>%
    dplyr::group_by(Especie) %>%
    dplyr::summarise(Total = sum(Abundancia, na.rm = TRUE), .groups = "drop") %>%
