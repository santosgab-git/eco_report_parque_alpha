# =====================================================================
# FUNCIÓN DE SELECCIÓN 
# =====================================================================
seleccionar_especies_foto_global <- function(df, max_total = 6) {
  
  df_proc <- df %>%
    dplyr::mutate(
      Dist_clean  = toupper(trimws(Distribucion)),
      IUCN_clean  = toupper(trimws(IUCN)),
      CITES_clean = toupper(trimws(CITES)),
      
      Peso = dplyr::case_when(
        grepl("END[ÉE]MICA|CE", Dist_clean) ~ 1,            
        grepl("\\(CR\\)|\\(EN\\)", IUCN_clean) ~ 2,
        grepl("AP[ÉE]NDICE", CITES_clean) ~ 3,
        grepl("\\(VU\\))", IUCN_clean) ~ 4,
        TRUE ~ 5
      )
    )

  df_ranking <- df_proc %>%
    dplyr::group_by(Especie) %>%
    dplyr::summarise(
      Prioridad_Min = min(Peso),
      Total_Abundancia = sum(Abundancia, na.rm = TRUE),

      Total_Ahuy = sum(Abundancia[Manejo == "Ahuyentamiento"], na.rm = TRUE),
      Total_Resc = sum(Abundancia[Manejo == "Rescate"], na.rm = TRUE),

      .groups = "drop"
    ) %>%
    dplyr::mutate(
     
      Bonus_Manejo = ifelse(Total_Ahuy > 0 & Total_Resc > 0, 1, 0)
    ) %>%
    dplyr::arrange(
      Prioridad_Min,                  
      desc(Bonus_Manejo),             
      desc(Total_Abundancia)          
    )

  return(df_ranking %>% dplyr::slice(1:max_total) %>% dplyr::pull(Especie))
}

