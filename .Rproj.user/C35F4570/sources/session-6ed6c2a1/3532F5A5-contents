  # =========================
  cons <- df_proc %>%
    dplyr::filter(!is.na(Categoria_Cons)) %>%
    dplyr::group_by(Especie) %>%
    dplyr::summarise(
      Categoria = paste(unique(Categoria_Cons), collapse = ", "),
      Total = sum(Abundancia, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    dplyr::arrange(Categoria, Total)

  especies_cons <- cons$Especie

  # =========================
