```{r}
#| label: Configuración inicial y creación de funciones

# ===========================================
# DEFINICIÓN DE GRUPOS BIOLÓGICOS
# ===========================================
grupos <- list(
  anfibios = "Amphibia",
  reptiles = "Reptilia",
  aves = "Aves",
  mamiferos = "Mammalia"
)

# ===========================================
# FUNCIÓN: PLURALIZAR PALABRAS
# ===========================================

pluralizar <- function(n, singular, plural) {
  if (n == 1) singular else plural
}

# ===========================================
# FUNCIÓN: TOP N CON EMPATES Y DOMINANCIA
# ===========================================

top_n_con_empates <- function(df, var, n = 3, es_especie = FALSE) {
  
  resumen <- df %>%
    mutate(valor = trimws(.data[[var]])) %>%
    group_by(valor) %>%
    summarise(total = sum(Abundancia), .groups = "drop") %>%
    arrange(desc(total))
  
  if (nrow(resumen) == 0) {
    return(list(texto = NULL, n = 0))
  }
  
  max_val <- max(resumen$total)
  
  # =========================
  # SOLO UNA CATEGORÍA
  # =========================
  if (nrow(resumen) == 1) {
    
    nombre <- resumen$valor[1]
    
    if (es_especie) {
      nombre <- paste0("\\textit{", nombre, "}")
    }
    
    texto <- paste0(nombre, " (n = ", max_val, ")")
    
    # aclaración de única
    if (es_especie) {
      texto <- paste0(texto, ", siendo la única especie registrada")
    } else {
      texto <- paste0(texto, ", siendo el único sitio con registros")
    }
    
    return(list(texto = texto, n = 1))
  }
  
  # =========================
  # DOMINANCIA RELATIVA (≥70%)
  # =========================
  umbral <- 0.7 * max_val
  
  top <- resumen %>%
    filter(total >= umbral) %>%
    distinct(valor, .keep_all = TRUE)
  
  mostrar <- top %>% slice(1:min(n, nrow(top)))
  restantes <- nrow(top) - nrow(mostrar)
  
  # =========================
  # CONSTRUIR NOMBRES
  # =========================
  lista_nombres <- mostrar %>%
    mutate(
      nombre = if (es_especie) {
        paste0("\\textit{", valor, "}")
      } else {
        valor
      }
    ) %>%
    pull(nombre)
  
  texto <- formatear_lista(lista_nombres)
  
  # =========================
  # RESTANTES
  # =========================
  if (restantes > 0) {
    
    tipo_extra <- if (es_especie) {
      if (restantes == 1) "otra especie" else paste0("otras ", restantes, " especies")
    } else {
      if (restantes == 1) "otra área" else paste0("otras ", restantes, " áreas")
    }
    
    texto <- paste0(texto, " y ", tipo_extra)
  }
  
  # =========================
  # EMPATES VS DOMINANCIA
  # =========================
  if (length(unique(mostrar$total)) == 1 && nrow(mostrar) > 1) {
    
    # EMPATE REAL
    lista_nombres <- mostrar %>%
      mutate(
        nombre = if (es_especie) {
          paste0("\\textit{", valor, "}")
        } else {
          valor
        }
      ) %>%
      pull(nombre)
    
    texto <- paste0(
      formatear_lista(lista_nombres),
      ", ",
      ifelse(nrow(mostrar) == 2, "ambas", "todas"),
      " con igual ",
      ifelse(es_especie, "abundancia", "número de individuos"),
      " (n = ", mostrar$total[1], ")"
    )
    
  } else {
    
    # DOMINANCIA NORMAL (con n = x por cada uno)
    lista_txt <- mostrar %>%
      mutate(
        nombre = if (es_especie) {
          paste0("\\textit{", valor, "}")
        } else {
          valor
        },
        txt = paste0(nombre, " (n = ", total, ")")
      ) %>%
      pull(txt)
    
    texto <- formatear_lista(lista_txt)
  }
  
  return(list(texto = texto, n = nrow(mostrar)))
}

