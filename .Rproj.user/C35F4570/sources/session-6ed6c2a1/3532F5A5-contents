# ===========================================
# FUNCIÓN: GENERAR TEXTO DEL REPORTE
# ===========================================

generar_texto <- function(df, tabla, mes, año) {

  # ======================
  # VALIDACIÓN INICIAL
  # ======================

  if (is.null(df) || nrow(df) == 0) {
    return(paste0(
      "No se registraron individuos de fauna durante el mes de ",
      mes, " de ", año, "."
    ))
  }

  total <- tabla %>%
  filter(Clase == "Total") %>%
  pull(Total)

  if (total == 0) {
    return(paste0(
      "No se registraron individuos de fauna durante el mes de ",
      mes, " de ", año, "."
    ))
  }

  # ======================
  # MÉTRICAS GENERALES
  # ======================

  n_especies <- n_distinct(df$Especie)
  n_familias <- n_distinct(df$Familia)
  n_ordenes  <- n_distinct(df$Orden)

  clases <- tabla %>%
    filter(Clase != "Total", Total > 0) %>%
    pull(Clase)

  # ======================
  # TEXTO BASE
  # ======================

  texto <- paste0(
    "Para el mes de ", mes, " de ", año,
    " se registraron ", total, " individuos en ",
    n_especies, " especies, ", n_familias,
    " familias y ", n_ordenes,
    " órdenes, pertenecientes a las clases ",
    formatear_lista(clases),
    " (**@fig-general****A**, **@tbl-clase-manejo**). "
  )

  # ======================
  # AHUYENTAMIENTO
  # ======================

  df_ahu <- df %>% filter(Manejo == "Ahuyentamiento")
  total_ahu <- sum(df_ahu$Abundancia, na.rm = TRUE)

  if (total_ahu > 0) {

    clases_ahu <- df_ahu %>%
      group_by(Clase) %>%
      summarise(n = sum(Abundancia), .groups="drop") %>%
      arrange(desc(n)) %>%
      mutate(txt = paste0(Clase, " (n = ", n, ")")) %>%
      pull(txt)

    actividades_ahu <- df_ahu %>%
      group_by(Actividad) %>%
      summarise(n = sum(Abundancia), .groups="drop") %>%
      arrange(desc(n)) %>%
      mutate(txt = paste0(Actividad, " (n = ", n, ")")) %>%
      pull(txt)

    texto <- paste0(
      texto,
      "Se manejaron ", total_ahu,
      " individuos mediante ahuyentamiento, principalmente en ",
      formatear_lista(clases_ahu),
      " (**@fig-general****B**)",
      ", en actividades de ",
      formatear_lista(actividades_ahu),
      " (**@fig-general****C**). "
    )
  }

  # ======================
  # RESCATE
  # ======================

  df_res <- df %>% filter(Manejo == "Rescate")
  total_res <- sum(df_res$Abundancia, na.rm = TRUE)

  if (total_res > 0) {

    clases_res <- df_res %>%
      group_by(Clase) %>%
      summarise(n = sum(Abundancia), .groups="drop") %>%
      arrange(desc(n)) %>%
      mutate(txt = paste0(Clase, " (n = ", n, ")")) %>%
      pull(txt)

    actividades_res <- df_res %>%
      group_by(Actividad) %>%
      summarise(n = sum(Abundancia), .groups="drop") %>%
      arrange(desc(n)) %>%
      mutate(txt = paste0(Actividad, " (n = ", n, ")")) %>%
      pull(txt)

    texto <- paste0(
      texto,
      "\n\n", 
      "Se rescataron ", total_res,
      " individuos, correspondientes a ",
      formatear_lista(clases_res),
      " (**@fig-general****B**)",
      ", en actividades de ",
      formatear_lista(actividades_res),
      " (**@fig-general****C**)."
    )
  }

  texto
}

# ===========================================
# GENERAR TEXTO FINAL
# ===========================================

if (!hay_datos || is.null(df) || nrow(df) == 0) {

  texto <- "No se registraron individuos de fauna durante el periodo evaluado.\n"

} else {

  texto <- generar_texto(df, tabla, MES, AÑO)

}
