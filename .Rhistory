filter(str_detect(Dist_clean, "ENDÉMICA|\\bCE\\b|CASI")) %>%
mutate(
etiqueta = case_when(
str_detect(Dist_clean, "CASI|\\bCE\\b") ~ "casi endémica",
str_detect(Dist_clean, "ENDÉMICA") ~ "endémica"
)
) %>%
distinct(Especie, Nombre_comun, etiqueta)
txt_end <- NULL
if (nrow(esp_end_df) > 0) {
lista <- esp_end_df %>%
mutate(txt = paste0(
cap_nombre(Nombre_comun),
" (\\textit{", Especie, "}, ", etiqueta, ")"
)) %>%
pull(txt)
if (length(lista) == 1) {
txt_end <- paste0(
"se resalta el registro de la especie ",
lista,
", lo que incrementa su vulnerabilidad frente a la pérdida de hábitat y resalta la relevancia ecológica del área intervenida. El manejo exitoso y el monitoreo de estos taxones es imperativo, dado que su carácter irremplazable implica que cualquier medida de protección local tiene un impacto directo en la conservación del patrimonio genético global de estas especies."
)
} else {
txt_end <- paste0(
"se registraron especies con restricción geográfica, tales como ",
formatear_lista(lista),
", lo que incrementa su vulnerabilidad frente a la pérdida de hábitat y resalta la relevancia ecológica del área intervenida. El manejo exitoso y el monitoreo de estos taxones es imperativo, dado que su carácter irremplazable implica que cualquier medida de protección local tiene un impacto directo en la conservación del patrimonio genético global de estas especies."
)
}
}
# =========================================
# ENSAMBLE DINÁMICO
# =========================================
parrafos <- list(
iucn = txt_iucn,
cites = txt_cites,
end = txt_end
)
parrafos <- parrafos[!sapply(parrafos, is.null)]
n <- length(parrafos)
# conectores dinámicos reales
conectores <- c("En relación con", "Respecto a", "Finalmente")
if (n == 1) conectores <- conectores[1]
if (n == 2) conectores <- conectores[1:2]
if (n == 3) conectores <- conectores[1:3]
# =========================================
# SALIDA FINAL
# =========================================
if (n > 0) {
cat(
"Durante el periodo de ", MES, " de ", AÑO,
", se destacan especies de interés para la conservación. ",
conectores[1], " ",
parrafos[[1]], "\n\n",
sep = ""
)
if (n > 1) {
for (i in 2:n) {
cat(
conectores[i], " ",
parrafos[[i]], "\n\n",
sep = ""
)
}
}
}
