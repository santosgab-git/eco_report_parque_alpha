group_by(CITES_num) %>%
summarise(
lista = list(
formatear_lista(
paste0(
cap_nombre(Nombre_comun),
" (\\textit{", Especie, "})"
)
)
),
.groups = "drop"
) %>%
mutate(
texto = paste0(
"Apéndice ", CITES_num, ": ",
lista
)
) %>%
pull(texto)
# manejar conectores ; y
partes_txt <- if (length(partes) == 1) {
partes
} else {
