esp_cites_df <- df_cons %>%
filter(str_detect(CITES_clean, "APÉNDICE")) %>%
mutate(CITES_num = str_extract(CITES_clean, "(?<=APÉNDICE )I{1,3}")) %>%
distinct(Especie, Nombre_comun, CITES_num)
txt_cites <- NULL
if (nrow(esp_cites_df) > 0) {
partes <- esp_cites_df %>%
group_by(CITES_num) %>%
summarise(
lista = list(
formatear_lista(
paste0(
cap_nombre(Nombre_comun),
" (\\textit{", Especie, "})"
)
)
),
.groups = "drop"
) %>%
mutate(
texto = paste0(
"Apéndice ", CITES_num, ": ",
lista
)
) %>%
pull(texto)
# manejar conectores ; y
partes_txt <- if (length(partes) == 1) {
partes
} else {
paste0(
paste(partes[-length(partes)], collapse = "; "),
" y ",
partes[length(partes)]
)
}
# singular vs plural
sujeto <- ifelse(nrow(esp_cites_df) == 1,
"la convención CITES, se gestionó de manera efectiva una especie incluida en ",
"la convención CITES, se gestionaron de manera efectiva especies incluidas en ")
txt_cites <- paste0(
sujeto,
ifelse(length(partes) > 1,
paste0("diferentes apéndices de la CITES, específicamente en ", partes_txt),
partes_txt),
". La inclusión en estos apéndices no solo implica restricciones al comercio internacional, sino que obliga al proyecto a garantizar que la intervención antrópica no afecte la viabilidad de sus poblaciones locales."
)
}
# =========================================
# ENDEMISMO
# =========================================
esp_end_df <- df_cons %>%
filter(str_detect(Dist_clean, "ENDÉMICA|\\bCE\\b|CASI")) %>%
mutate(
etiqueta = case_when(
str_detect(Dist_clean, "CASI|\\bCE\\b") ~ "casi endémica",
str_detect(Dist_clean, "ENDÉMICA") ~ "endémica"
)
) %>%
distinct(Especie, Nombre_comun, etiqueta)
txt_end <- NULL
if (nrow(esp_end_df) > 0) {
lista <- esp_end_df %>%
mutate(txt = paste0(
cap_nombre(Nombre_comun),
" (\\textit{", Especie, "}, ", etiqueta, ")"
)) %>%
pull(txt)
if (length(lista) == 1) {
txt_end <- paste0(
"se resalta el registro de la especie ",
lista,
", lo que incrementa su vulnerabilidad frente a la pérdida de hábitat y resalta la relevancia ecológica del área intervenida. El manejo exitoso y el monitoreo de estos taxones es imperativo, dado que su carácter irremplazable implica que cualquier medida de protección local tiene un impacto directo en la conservación del patrimonio genético global de estas especies."
)
} else {
txt_end <- paste0(
"se registraron especies con restricción geográfica, tales como ",
formatear_lista(lista),
", lo que incrementa su vulnerabilidad frente a la pérdida de hábitat y resalta la relevancia ecológica del área intervenida. El manejo exitoso y el monitoreo de estos taxones es imperativo, dado que su carácter irremplazable implica que cualquier medida de protección local tiene un impacto directo en la conservación del patrimonio genético global de estas especies."
)
}
}
# =========================================
# ENSAMBLE DINÁMICO
# =========================================
parrafos <- list(
iucn = txt_iucn,
cites = txt_cites,
end = txt_end
)
parrafos <- parrafos[!sapply(parrafos, is.null)]
n <- length(parrafos)
# conectores dinámicos reales
conectores <- c("En relación con", "Respecto a", "Finalmente")
if (n == 1) conectores <- conectores[1]
if (n == 2) conectores <- conectores[1:2]
if (n == 3) conectores <- conectores[1:3]
# salida
if (n > 0) {
# =========================================
# SALIDA FINAL
# =========================================
if (n > 0) {
# PRIMER PÁRRAFO
cat(
"Durante el periodo de ", MES, " de ", AÑO, ", ",
tolower(conectores[1]), " ",
parrafos[[1]], "\n\n",
sep = ""
)
# RESTO DE PÁRRAFOS
if (n > 1) {
for (i in 2:n) {
cat(
conectores[i], " ",
parrafos[[i]], "\n\n",
sep = ""
)
}
}
#| label: prep-especies-conservacion
#| echo: false
#| results: asis
library(dplyr)
library(stringr)
# =========================================
# LIMPIEZA BASE
# =========================================
df_cons <- df %>%
mutate(
IUCN_code = str_extract(IUCN, "\\((.*?)\\)") %>%
str_remove_all("[()]") %>%
toupper(),
CITES_clean = toupper(trimws(CITES)),
Dist_clean = toupper(trimws(Distribucion))
)
# =========================================
# FUNCIONES AUXILIARES
# =========================================
formatear_lista <- function(x) {
if (length(x) == 0) return(NULL)
if (length(x) == 1) return(x)
conj <- ifelse(grepl("^[iI]", x[length(x)]), " e ", " y ")
paste0(
paste(x[-length(x)], collapse = ", "),
conj,
x[length(x)]
)
}
# Traducción IUCN
traducir_iucn <- function(x){
case_when(
x == "CR" ~ "En Peligro Crítico (CR)",
x == "EN" ~ "En Peligro (EN)",
x == "VU" ~ "Vulnerable (VU)",
TRUE ~ x
)
}
# Capitalizar nombre común
cap_nombre <- function(x){
str_to_sentence(x)
}
# =========================================
# IUCN
# =========================================
esp_iucn_df <- df_cons %>%
filter(IUCN_code %in% c("CR","EN","VU")) %>%
distinct(Especie, Nombre_comun, IUCN_code)
txt_iucn <- NULL
if (nrow(esp_iucn_df) > 0) {
if (nrow(esp_iucn_df) == 1) {
fila <- esp_iucn_df[1,]
nombre <- cap_nombre(fila$Nombre_comun)
especie <- fila$Especie
categoria <- traducir_iucn(fila$IUCN_code)
txt_iucn <- paste0(
"las categorías de la UICN, se destaca el registro de la especie ", nombre,
" (\\textit{", especie, "}), categorizada como ", categoria,
". El manejo de estos especímenes es crítico, dado que que según la Resolución 0126 de 2024 del Ministerio de Ambiente y Desarrollo Sostenible, la región Caribe alberga el 16,8% de las especies amenazadas del país; por tanto, su manejo exitoso no solo cumple con el PMA, sino que contribuye directamente a la mitigación del impacto sobre la biodiversidad nacional."
)
} else {
lista <- esp_iucn_df %>%
mutate(txt = paste0(
cap_nombre(Nombre_comun),
" (\\textit{", Especie, "}, ", traducir_iucn(IUCN_code), ")"
)) %>%
pull(txt)
txt_iucn <- paste0(
"las categorías de la UICN, se registraron especies categorizadas tales como ",
formatear_lista(lista),
". El manejo de estos especímenes es crítico, dado que que según la Resolución 0126 de 2024 del Ministerio de Ambiente y Desarrollo Sostenible, la región Caribe alberga el 16,8% de las especies amenazadas del país; por tanto, su manejo exitoso no solo cumple con el PMA, sino que contribuye directamente a la mitigación del impacto sobre la biodiversidad nacional."
)
}
}
# =========================================
# CITES
# =========================================
esp_cites_df <- df_cons %>%
filter(str_detect(CITES_clean, "APÉNDICE")) %>%
mutate(CITES_num = str_extract(CITES_clean, "(?<=APÉNDICE )I{1,3}")) %>%
distinct(Especie, Nombre_comun, CITES_num)
txt_cites <- NULL
if (nrow(esp_cites_df) > 0) {
partes <- esp_cites_df %>%
group_by(CITES_num) %>%
summarise(
lista = list(
formatear_lista(
paste0(
cap_nombre(Nombre_comun),
" (\\textit{", Especie, "})"
)
)
),
.groups = "drop"
) %>%
mutate(
texto = paste0(
"Apéndice ", CITES_num, ": ",
lista
)
) %>%
pull(texto)
# manejar conectores ; y
partes_txt <- if (length(partes) == 1) {
partes
} else {
paste0(
paste(partes[-length(partes)], collapse = "; "),
" y ",
partes[length(partes)]
)
}
# singular vs plural
sujeto <- ifelse(nrow(esp_cites_df) == 1,
"la convención CITES, se gestionó de manera efectiva una especie incluida en ",
"la convención CITES, se gestionaron de manera efectiva especies incluidas en ")
txt_cites <- paste0(
sujeto,
ifelse(length(partes) > 1,
paste0("diferentes apéndices de la CITES, específicamente en ", partes_txt),
partes_txt),
". La inclusión en estos apéndices no solo implica restricciones al comercio internacional, sino que obliga al proyecto a garantizar que la intervención antrópica no afecte la viabilidad de sus poblaciones locales."
)
}
# =========================================
# ENDEMISMO
# =========================================
esp_end_df <- df_cons %>%
filter(str_detect(Dist_clean, "ENDÉMICA|\\bCE\\b|CASI")) %>%
mutate(
etiqueta = case_when(
str_detect(Dist_clean, "CASI|\\bCE\\b") ~ "casi endémica",
str_detect(Dist_clean, "ENDÉMICA") ~ "endémica"
)
) %>%
distinct(Especie, Nombre_comun, etiqueta)
txt_end <- NULL
if (nrow(esp_end_df) > 0) {
lista <- esp_end_df %>%
mutate(txt = paste0(
cap_nombre(Nombre_comun),
" (\\textit{", Especie, "}, ", etiqueta, ")"
)) %>%
pull(txt)
if (length(lista) == 1) {
txt_end <- paste0(
"se resalta el registro de la especie ",
lista,
", lo que incrementa su vulnerabilidad frente a la pérdida de hábitat y resalta la relevancia ecológica del área intervenida. El manejo exitoso y el monitoreo de estos taxones es imperativo, dado que su carácter irremplazable implica que cualquier medida de protección local tiene un impacto directo en la conservación del patrimonio genético global de estas especies."
)
} else {
txt_end <- paste0(
"se registraron especies con restricción geográfica, tales como ",
formatear_lista(lista),
", lo que incrementa su vulnerabilidad frente a la pérdida de hábitat y resalta la relevancia ecológica del área intervenida. El manejo exitoso y el monitoreo de estos taxones es imperativo, dado que su carácter irremplazable implica que cualquier medida de protección local tiene un impacto directo en la conservación del patrimonio genético global de estas especies."
)
}
}
# =========================================
# ENSAMBLE DINÁMICO
# =========================================
parrafos <- list(
iucn = txt_iucn,
cites = txt_cites,
end = txt_end
)
parrafos <- parrafos[!sapply(parrafos, is.null)]
n <- length(parrafos)
# conectores dinámicos reales
conectores <- c("En relación con", "Respecto a", "Finalmente")
if (n == 1) conectores <- conectores[1]
if (n == 2) conectores <- conectores[1:2]
if (n == 3) conectores <- conectores[1:3]
# =========================================
# SALIDA FINAL
# =========================================
if (n > 0) {
# PRIMER PÁRRAFO (integrado con "Durante el periodo...")
cat(
"Durante el periodo de ", MES, " de ", AÑO, ", ",
tolower(conectores[1]), " ",
parrafos[[1]], "\n\n",
sep = ""
)
# RESTO DE PÁRRAFOS
if (n > 1) {
for (i in 2:n) {
cat(
conectores[i], " ",
parrafos[[i]], "\n\n",
sep = ""
)
}
}
}
